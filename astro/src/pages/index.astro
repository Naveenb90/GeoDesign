---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="GeoDesign — Reduce Construction Risk in India"
  description="GeoDesign reduces construction risk using scientific geotechnical expertise — soil investigation, testing, and foundation insight across Tamil Nadu, Coimbatore & Chennai."
  canonicalPath="/"
>
  <main id="main-content" class="mx-auto flex min-h-[60vh] max-w-4xl flex-col justify-center px-4 py-16">
    <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-sky-700">Astro preview</p>
    <h1 class="mb-4 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      GeoDesign marketing site (Astro)
    </h1>
    <p class="mb-8 max-w-2xl text-lg leading-relaxed text-slate-600">
      This branch builds a static, SEO-first site under <code class="rounded bg-slate-100 px-1.5 py-0.5 text-sm">astro/</code>.
      The legacy Vite + React app remains at the repository root until routes are migrated.
    </p>
    <p class="text-sm text-slate-500">
      Meta tags and JSON-LD in <code class="rounded bg-slate-100 px-1 py-0.5 text-xs">BaseLayout.astro</code> ship in the first HTML response.
    </p>
  </main>
</BaseLayout>

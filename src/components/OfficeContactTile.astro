---
import OfficePhoneRow from './OfficePhoneRow.astro';
import { SKY_OFFICE_TILE_SHELL_CLASS } from '../data/skyTileClasses.js';

interface Props {
  heading: string;
  regionLabel: string;
  address: string;
  landline?: string;
  mobile: string;
  email: string;
  officeLabel: string;
}

const { heading, regionLabel, address, landline, mobile, email, officeLabel } = Astro.props;

const shell = SKY_OFFICE_TILE_SHELL_CLASS;
const rowGrid = 'grid grid-cols-[2.75rem_1fr] items-start gap-x-3';
---

<div class={`${shell} flex h-full flex-col p-5 text-left shadow-sm transition-shadow duration-300 hover:shadow-md sm:p-6`}>
  <header class="mb-3 border-b border-sky-100/80 pb-3">
    <h2 class="text-xl font-bold tracking-tight text-slate-900 sm:text-2xl">{heading}</h2>
    <p class="mt-0.5 text-sm text-slate-600">{regionLabel}</p>
  </header>

  <address class="not-italic">
    <div class="flex flex-col gap-2.5 text-sm leading-snug text-slate-600 sm:gap-3 sm:text-[0.9375rem] sm:leading-relaxed">
      <div class={rowGrid}>
        <span class="flex justify-center pt-0.5 text-base leading-none" aria-hidden="true">📍</span>
        <span class="min-w-0 pt-0.5">{address}</span>
      </div>
      {
        landline ? (
          <div class={rowGrid}>
            <span class="flex justify-center pt-0.5 text-base leading-none" aria-hidden="true">
              📞
            </span>
            <span class="tabular-nums pt-0.5">{landline}</span>
          </div>
        ) : null
      }
      <OfficePhoneRow phone={mobile} officeLabel={officeLabel} />
      <div class={rowGrid}>
        <span class="flex justify-center pt-0.5 text-base leading-none" aria-hidden="true">✉️</span>
        <a
          href={`mailto:${email}`}
          class="min-w-0 break-all pt-0.5 hover:text-sky-700 hover:underline sm:break-normal"
        >
          {email}
        </a>
      </div>
    </div>
  </address>
</div>

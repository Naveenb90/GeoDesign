---
/**
 * FAQ accordion — native `<details>`/`<summary>`, zero JavaScript.
 *
 * Deliberately not a React island:
 *  - keyboard and screen-reader behaviour is free and correct
 *  - answers stay in the DOM, so they remain crawlable (Google indexes
 *    `<details>` content) — important because these feed FAQPage schema in a
 *    later batch
 *  - keeps the site's near-zero JS profile intact
 *
 * Items are left independently toggleable rather than mutually exclusive; for a
 * reference FAQ list that is the more useful behaviour.
 */
interface Props {
  items: { question: string; answer: string }[];
  /** Heading level for each question. Pages with an H1 should keep the default. */
  headingLevel?: 'h3' | 'h4';
  class?: string;
}

const { items, headingLevel: HeadingTag = 'h3', class: className = '' } = Astro.props;
---

<div class:list={['divide-y divide-slate-200/90 border-y border-slate-200/90', className]}>
  {
    items.map((item) => (
      <details class="faq-item group">
        <summary
          class="flex cursor-pointer list-none items-start justify-between gap-4 py-5 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
        >
          <HeadingTag class="font-display m-0 text-base font-semibold leading-snug text-slate-900 md:text-lg">
            {item.question}
          </HeadingTag>
          <span
            class="faq-marker mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-sky-200 bg-sky-50 text-sky-700 transition-transform duration-200"
            aria-hidden="true"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="pb-6 pr-11">
          <p class="m-0 text-sm leading-relaxed text-slate-600 md:text-base">{item.answer}</p>
        </div>
      </details>
    ))
  }
</div>

<style>
  /* Hide the default disclosure triangle across engines. */
  .faq-item > summary::-webkit-details-marker {
    display: none;
  }
  .faq-item > summary::marker {
    content: '';
  }

  .faq-item[open] .faq-marker {
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-marker {
      transition: none;
    }
  }
</style>

---
import { navLinks } from '../data/data.js';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

/** Desktop nav — pill row: active elevated chip; inactive glass hover. */
const desktopNavLinkClass = (href: string) => {
  const active = currentPath === href;
  return active
    ? 'bg-gradient-to-b from-white to-sky-50 text-sky-900 shadow-sm ring-1 ring-sky-200/70'
    : 'text-slate-600 hover:bg-white/95 hover:text-sky-900 hover:shadow-sm ring-1 ring-transparent hover:ring-slate-200/60';
};

const mobileLinkClass = (href: string) => {
  const active = currentPath === href;
  return active
    ? 'border-sky-200 bg-sky-50 text-sky-900 ring-1 ring-sky-100'
    : 'border-transparent text-slate-700 hover:border-slate-200 hover:bg-white';
};
---

<header
  id="site-header"
  class="header-site fixed left-0 top-0 z-50 w-full border-b border-slate-200 bg-slate-100 transition-[padding,box-shadow] duration-300 motion-reduce:transition-none"
  role="banner"
>
  <div
    class="mx-auto grid w-full min-w-0 max-w-7xl grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 px-3 py-3 sm:gap-4 sm:px-5 md:py-3.5 lg:grid-cols-[auto_minmax(0,1fr)] lg:gap-x-4 lg:px-8"
  >
    <a
      href="/"
      class="group flex min-w-0 max-w-[min(100%,42rem)] items-center gap-3 sm:gap-4"
    >
      <img
        src="/assets/web/logo.png"
        alt="GeoDesign Logo"
        class="h-12 w-12 shrink-0 object-contain sm:h-14 sm:w-14 md:h-16 md:w-16 lg:h-[4.5rem] lg:w-[4.5rem] xl:h-20 xl:w-20"
        width="96"
        height="96"
        loading="eager"
      />
      <div class="flex min-w-0 flex-col gap-0.5 sm:gap-1">
        <p
          class="font-display min-w-0 whitespace-nowrap text-[0.8125rem] font-semibold uppercase leading-tight tracking-[0.04em] text-slate-900 transition-colors group-hover:text-sky-900 sm:text-base md:text-lg lg:text-[1.125rem]"
        >
          <span>GEODESIGN INDIA PRIVATE LIMITED</span><sup
            class="ml-0.5 align-super text-[0.55em] font-normal tracking-normal">&reg;</sup>
        </p>
        <p class="text-[0.5625rem] leading-snug text-slate-600 sm:text-[0.6875rem] md:text-xs">
          A Unit of Geotechnical Engineers
        </p>
        <p class="text-[0.5625rem] leading-snug text-slate-500 sm:text-[0.6875rem] md:text-xs">
          DTCP &amp; CMDA Chennai, Registered Engineers
        </p>
      </div>
    </a>

    <div class="col-start-2 flex min-w-0 max-w-full items-center justify-end gap-2 lg:min-w-0 xl:gap-3">
      <div class="hidden w-full min-w-0 max-w-full items-center justify-end gap-2 lg:flex lg:gap-2.5 xl:gap-4">
        <nav
          class="inline-flex min-w-0 max-w-full flex-nowrap items-center justify-end gap-0.5 overflow-x-auto overscroll-x-contain rounded-full border border-slate-200/90 bg-white/80 p-1 shadow-[0_1px_2px_rgba(15,23,42,0.06),inset_0_1px_0_rgba(255,255,255,0.85)] ring-1 ring-slate-300/15 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden sm:gap-px"
          role="navigation"
          aria-label="Main navigation"
        >
          <a
            href="/"
            aria-current={currentPath === '/' ? 'page' : undefined}
            class={`font-display inline-flex shrink-0 whitespace-nowrap rounded-full px-1.5 py-1.5 text-[0.625rem] font-semibold leading-tight tracking-wide transition-all duration-200 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-100 sm:px-2 sm:py-2 sm:text-[0.6875rem] lg:px-2 lg:text-[0.7rem] xl:px-2.5 xl:text-[0.75rem] 2xl:px-3 2xl:text-[0.8125rem] ${desktopNavLinkClass('/')}`}
          >
            Home
          </a>
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                aria-current={currentPath === link.href ? 'page' : undefined}
                class={`font-display inline-flex shrink-0 whitespace-nowrap rounded-full px-1.5 py-1.5 text-[0.625rem] font-semibold leading-tight tracking-wide transition-all duration-200 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-100 sm:px-2 sm:py-2 sm:text-[0.6875rem] lg:px-2 lg:text-[0.7rem] xl:px-2.5 xl:text-[0.75rem] 2xl:px-3 2xl:text-[0.8125rem] ${desktopNavLinkClass(link.href)}`}
              >
                {link.label}
              </a>
            ))
          }
        </nav>

        <span
          class="hidden h-9 w-px shrink-0 bg-gradient-to-b from-transparent via-slate-300/90 to-transparent sm:block"
          aria-hidden="true"
        ></span>

        <a
          href="/contact"
          aria-current={currentPath === '/contact' ? 'page' : undefined}
          class:list={[
            'font-display inline-flex shrink-0 items-center justify-center rounded-full px-2.5 py-1.5 text-[0.625rem] font-bold tracking-wide shadow-md transition-all duration-200 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-100 sm:px-3 sm:py-2 sm:text-[0.6875rem] lg:text-[0.7rem] xl:px-4 xl:text-xs',
            currentPath === '/contact'
              ? 'bg-gradient-to-b from-sky-700 to-sky-900 text-white ring-2 ring-sky-400/60 ring-offset-2 ring-offset-slate-100 shadow-sky-900/25'
              : 'bg-gradient-to-b from-sky-500 to-sky-700 text-white shadow-sky-900/20 ring-1 ring-white/25 hover:from-sky-400 hover:to-sky-600 hover:shadow-lg',
          ]}
        >
          Get in Touch
        </a>
      </div>

      <button
        id="menu-btn"
        type="button"
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-700 shadow-sm transition-colors hover:border-sky-300 hover:bg-sky-50 hover:text-sky-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path
            id="menu-icon-close"
            class="hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu-wrap" class="lg:hidden" hidden>
    <nav
      id="mobile-menu"
      class="flex max-h-[min(85vh,28rem)] flex-col gap-0.5 overflow-y-auto overscroll-contain border-t border-slate-200 bg-slate-100 px-3 pb-4 pt-2 shadow-lg sm:px-4"
      role="navigation"
      aria-label="Mobile navigation"
    >
      <a
        href="/"
        class={`rounded-lg border px-4 py-3 font-sans text-[0.9375rem] font-medium leading-snug transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 ${mobileLinkClass('/')}`}
      >
        Home
      </a>
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`rounded-lg border px-4 py-3 font-sans text-[0.9375rem] font-medium leading-snug transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 ${mobileLinkClass(link.href)}`}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="mt-2 rounded-lg bg-sky-600 px-4 py-3 text-center font-sans text-[0.9375rem] font-semibold text-white shadow-sm transition-colors hover:bg-sky-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500"
      >
        Get in Touch
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var btn = document.getElementById('menu-btn');
    var wrap = document.getElementById('mobile-menu-wrap');
    var iconOpen = document.getElementById('menu-icon-open');
    var iconClose = document.getElementById('menu-icon-close');
    if (!header || !btn || !wrap) return;

    function setMenuOpen(open) {
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      if (open) {
        wrap.removeAttribute('hidden');
      } else {
        wrap.setAttribute('hidden', '');
      }
      if (iconOpen && iconClose) {
        iconOpen.classList.toggle('hidden', open);
        iconClose.classList.toggle('hidden', !open);
      }
    }

    btn.addEventListener('click', function () {
      var open = btn.getAttribute('aria-expanded') === 'true';
      setMenuOpen(!open);
    });

    wrap.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        setMenuOpen(false);
      });
    });

    window.addEventListener('scroll', function () {
      if (window.scrollY > 20) {
        header.classList.add('header-site--scrolled');
      } else {
        header.classList.remove('header-site--scrolled');
      }
    });
  })();
</script>

<style>
  .header-site.header-site--scrolled {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    box-shadow: 0 1px 0 0 rgb(226 232 240);
  }
  @media (min-width: 640px) {
    .header-site.header-site--scrolled {
      padding-top: 0.625rem;
      padding-bottom: 0.625rem;
    }
  }
</style>

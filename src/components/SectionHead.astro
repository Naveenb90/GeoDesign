---
/**
 * Shared section header — kicker + heading + optional intro.
 *
 * Replaces three near-identical header treatments that were hand-inlined across
 * `why-it-matters.astro`, `services/index.astro`, and `our-offices.astro`.
 *
 * The kicker/eyebrow pattern is adapted from the supplied sample design, restyled
 * to GeoDesign's sky/slate palette and Montserrat display face (no brass, no serif).
 */
interface Props {
  /** Small uppercase label above the heading, e.g. "Understanding site risk". */
  kicker?: string;
  heading: string;
  /** Supporting paragraph below the heading. */
  intro?: string;
  /** Heading level — pages already carrying an H1 should pass "h2". */
  as?: 'h1' | 'h2' | 'h3';
  /** `id` for the heading, so a parent section can use `aria-labelledby`. */
  id?: string;
  align?: 'left' | 'center';
  /** Larger scale for page-level headings. */
  size?: 'page' | 'section';
  class?: string;
}

const {
  kicker,
  heading,
  intro,
  as: Tag = 'h2',
  id,
  align = 'left',
  size = 'section',
  class: className = '',
} = Astro.props;

const headingSize =
  size === 'page'
    ? 'text-3xl sm:text-4xl md:text-5xl'
    : 'text-2xl md:text-3xl';

const alignment = align === 'center' ? 'mx-auto text-center' : '';
const kickerAlignment = align === 'center' ? 'justify-center' : '';
---

<header class:list={['max-w-3xl', alignment, className]}>
  {
    kicker ? (
      <p
        class:list={[
          'font-sans mb-3 flex items-center gap-2.5 text-xs font-semibold uppercase tracking-wider text-sky-700',
          kickerAlignment,
        ]}
      >
        <span class="h-px w-5 shrink-0 bg-sky-600" aria-hidden="true"></span>
        {kicker}
      </p>
    ) : null
  }

  <Tag
    id={id}
    class:list={['font-display font-bold leading-tight text-balance text-slate-900', headingSize]}
  >
    {heading}
  </Tag>

  {
    intro ? (
      <p class="mt-3 text-base leading-relaxed text-slate-600 md:text-lg">{intro}</p>
    ) : null
  }

  <slot />
</header>

---
import { geotechnicalServicePages } from '../data/servicesCatalog.js';
import { commercialServices } from '../data/commercialServices.js';
import Icon from './Icon.astro';

/**
 * "Related services" cross-link block.
 *
 * Directly addresses the audit's weakest finding: the site currently has almost no
 * cross-linking between service pages. Each service page linking to three siblings
 * spreads authority and gives users a next step other than the back button.
 *
 * Card hover (lift + accent rail + focus parity) is adapted from the sample design,
 * recoloured to sky. `:focus-visible` is styled identically to `:hover` so keyboard
 * users get the same affordance.
 */
interface Props {
  /** Slug of the current page, so it is never listed as related to itself. */
  currentSlug?: string;
  /** Explicit slugs to show. Falls back to the next services in catalog order. */
  slugs?: string[];
  heading?: string;
  limit?: number;
  class?: string;
}

const {
  currentSlug,
  slugs,
  heading = 'Related services',
  limit = 3,
  class: className = '',
} = Astro.props;

/** Related services may reference either tier. */
const ALL_SERVICES = [...commercialServices, ...geotechnicalServicePages];
const bySlug = (slug: string) => ALL_SERVICES.find((p) => p.slug === slug);

/** TS 5.5+ infers a type predicate from this filter, so `explicit` is non-nullable. */
const explicit = (slugs ?? []).map(bySlug).filter((p) => p !== undefined);

const fallback = ALL_SERVICES.filter((p) => p.slug !== currentSlug);

const related = (explicit.length ? explicit : fallback)
  .filter((p) => p.slug !== currentSlug)
  .slice(0, limit);
---

{
  related.length ? (
    <section class:list={['min-w-0', className]} aria-labelledby="related-services-heading">
      <h2
        id="related-services-heading"
        class="font-display mb-6 text-xl font-bold leading-tight text-slate-900 md:text-2xl"
      >
        {heading}
      </h2>

      <ul class="m-0 grid list-none gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3 md:gap-5" role="list">
        {related.map((svc) => (
          <li class="min-w-0">
            <a
              href={`/services/${svc.slug}`}
              class="related-card relative block h-full overflow-hidden rounded-xl border border-sky-200/70 bg-gradient-to-br from-sky-50/95 to-white p-5 shadow-sm ring-1 ring-sky-100/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
            >
              <span
                class="mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-white text-sky-700 ring-1 ring-sky-200/80"
                aria-hidden="true"
              >
                <Icon name={svc.iconKey} class="h-5 w-5" />
              </span>
              <h3 class="mb-1.5 text-base font-bold text-slate-900">{svc.title}</h3>
              <p class="mb-3 text-sm leading-snug text-slate-600">{svc.shortDescription}</p>
              <span class="text-sm font-semibold text-sky-700">View details →</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null
}

<style>
  .related-card {
    transition:
      transform 0.22s cubic-bezier(0.22, 0.68, 0.32, 1),
      box-shadow 0.22s ease,
      border-color 0.22s ease;
  }

  /* Accent rail slides in on hover/focus — adapted from the sample design. */
  .related-card::before {
    content: '';
    position: absolute;
    inset-block: 0;
    left: 0;
    width: 3px;
    background-color: var(--color-sky-500, #0ea5e9);
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .related-card:hover,
  .related-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 14px 30px -18px rgba(15, 23, 42, 0.45);
    border-color: var(--color-sky-300, #7dd3fc);
  }

  .related-card:hover::before,
  .related-card:focus-visible::before {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .related-card,
    .related-card::before {
      transition: none;
    }
    .related-card:hover,
    .related-card:focus-visible {
      transform: none;
    }
  }
</style>

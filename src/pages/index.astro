---
import SiteLayout from '../layouts/SiteLayout.astro';
import { HeroGalleryBackground } from '../components/HeroGalleryBackground.jsx';
import { homeHeroImages } from '../data/homeHeroImages.js';
import Icon from '../components/Icon.astro';

/** Order and files: `src/data/homeHeroImages.js` → `public/assets/home/` (see ROTATE_MS). */
const heroGalleryImages = homeHeroImages;

/**
 * Home page is hero-only, by decision.
 *
 * A credentials band, services grid, why-it-matters teaser, and CTA were trialled
 * below the hero and removed at Naveen's direction. The footer already carries
 * every service link plus the office NAP on every page, so the section duplicated
 * links a short scroll further down without extending reach.
 *
 * If anything is added back here later, note the SEO trade-off recorded in
 * `req/IMPLEMENTATION_RECORD.md`: this page carries little body copy, so it leans
 * on the hero text, title, and description for topical relevance.
 */
---

<SiteLayout
  title="GeoDesign — Reduce Construction Risk in India"
  description="We reduce risk in construction using scientific expertise — geotechnical investigation and testing across South India for residential, commercial, and government projects."
  canonicalPath="/"
><!--
  ogImagePath intentionally omitted so the page uses the purpose-built 1200×630
  `og-image.jpg` from BaseLayout. It previously passed `heroGalleryImages[0]`,
  which meant the social card image was whichever file sorted first in
  `public/assets/home/` — so dropping a new photo into that folder silently
  changed the OG image, and the one being served (construction.jpg, 800×579) did
  not match the declared 1200×630 dimensions.
-->
  <section
    id="hero"
    class="hero-full relative flex w-full flex-col items-center justify-center overflow-hidden pb-12 pt-20 sm:pb-16"
    aria-labelledby="hero-heading"
  >
    <HeroGalleryBackground client:load images={heroGalleryImages} />
    <div
      class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-b from-slate-50/25 via-transparent to-white/55"
      aria-hidden="true"
    ></div>
    <div class="relative z-10 mx-auto w-full max-w-5xl px-3 py-6 text-center sm:px-5 sm:py-8 md:px-6">
      <div class="rounded-2xl border border-white/40 bg-white/82 p-5 shadow-lg sm:rounded-3xl sm:p-8">
        <h1
          id="hero-heading"
          class="mb-3 font-sans text-[1.65rem] font-bold leading-tight tracking-normal text-slate-900 sm:mb-4 sm:font-display sm:text-3xl sm:leading-[1.25] sm:tracking-tight md:text-4xl lg:text-4xl"
        >
          <span class="block text-slate-900">Know your ground &amp;</span>
          <span class="mt-1 block text-sky-800 sm:mt-1.5">Build with confidence.</span>
        </h1>

        <p class="mx-auto mb-6 max-w-2xl text-[0.9375rem] leading-relaxed text-slate-700 sm:text-lg">
          We reduce risk in construction using scientific expertise — geotechnical investigation and testing
          across South India for residential, commercial, and government projects.
        </p>

        <p
          class="mb-4 flex w-full flex-wrap items-center justify-center gap-x-2 gap-y-1 font-sans text-sm tracking-wide sm:font-display sm:text-base"
        >
          <span class="text-sky-600" aria-hidden="true"><Icon name="award" class="h-5 w-5" /></span>
          <span class="text-base font-extrabold tabular-nums text-sky-600 sm:text-2xl">5,000+</span>
          <span class="text-[0.8125rem] font-semibold uppercase tracking-wide text-slate-800 sm:text-base">
            Projects Completed
          </span>
        </p>

        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex min-w-[200px] items-center justify-center rounded-xl bg-gradient-to-r from-sky-600 to-sky-700 px-8 py-3 font-semibold text-white shadow-md transition hover:from-sky-700 hover:to-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2"
            aria-label="Get a quote for geotechnical investigation"
          >
            Get a Quote
          </a>
          <a
            href="/video"
            class="inline-flex min-w-[200px] items-center justify-center rounded-xl border-2 border-slate-700/80 bg-white/50 px-6 py-3 font-semibold text-slate-900 transition hover:bg-white/80 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2"
            aria-label="Watch our video about soil testing"
          >
            Watch Video
          </a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  /*
    The hero must own its height.

    It previously used `flex-1`, which meant it simply absorbed whatever vertical
    space the footer left over. That was fine when the footer was a single
    copyright line, but the footer now carries four columns of navigation and both
    office addresses (~450px desktop, taller stacked on mobile). With `flex-1` the
    hero collapsed by exactly that amount and the footer rose into mid-screen.

    `svh` — small viewport height — is the correct unit here: on mobile it uses the
    viewport with browser chrome *visible*, so the hero never gets taller than the
    space actually on screen and the layout does not jump as the URL bar hides.
    `vh` is kept as a fallback for anything without `svh` support.
  */
  .hero-full {
    min-height: 100vh;
    min-height: 100svh;
  }

  /*
    Landscape phones are shorter than the hero content needs, so cap it there and
    let the section grow to fit rather than clipping the CTAs.
  */
  @media (max-height: 32rem) {
    .hero-full {
      min-height: 32rem;
    }
  }
</style>

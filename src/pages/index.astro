---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="GeoDesign — Reduce Construction Risk in India"
  description="We reduce risk in construction using scientific expertise — geotechnical investigation and testing across South India for residential, commercial, and government projects."
  canonicalPath="/"
>
  <section
    id="hero"
    class="relative flex min-h-0 w-full flex-1 flex-col items-center justify-center overflow-hidden bg-gradient-to-b from-slate-200 via-slate-100 to-white pb-12 pt-20 sm:pb-16"
    style="background-image: url('/assets/web/hero-site.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;"
    role="banner"
    aria-label="Hero section"
  >
    <div class="relative z-10 mx-auto w-full max-w-5xl px-3 py-6 text-center sm:px-5 sm:py-8 md:px-6">
      <div class="rounded-2xl bg-white/30 p-5 shadow-lg backdrop-blur-md sm:rounded-3xl sm:p-8">
        <h1
          class="mb-3 font-sans text-[1.65rem] font-bold leading-tight tracking-normal text-slate-900 sm:mb-4 sm:font-display sm:text-3xl sm:leading-[1.2] sm:tracking-tight md:text-4xl lg:text-4xl"
        >
          Know Your Ground.
          <span class="mt-1 block text-sky-800">Build With Confidence.</span>
        </h1>

        <p class="mx-auto mb-6 max-w-2xl text-[0.9375rem] leading-relaxed text-slate-700 sm:text-lg">
          We reduce risk in construction using scientific expertise — geotechnical investigation and testing
          across South India for residential, commercial, and government projects.
        </p>

        <p
          class="mb-4 flex w-full flex-wrap items-center justify-center gap-x-2 gap-y-1 font-sans text-sm tracking-wide sm:font-display sm:text-base"
        >
          <span class="select-none text-base leading-none sm:text-lg" aria-hidden="true">🏆</span>
          <span class="text-base font-extrabold tabular-nums text-sky-600 sm:text-2xl">5,000+</span>
          <span class="text-[0.8125rem] font-semibold uppercase tracking-wide text-slate-800 sm:text-base">
            Projects Completed
          </span>
        </p>

        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex min-w-[200px] items-center justify-center rounded-xl bg-gradient-to-r from-sky-600 to-sky-700 px-8 py-3 font-semibold text-white shadow-md transition hover:from-sky-700 hover:to-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2"
            aria-label="Get a quote for geotechnical investigation"
          >
            Get a Quote
          </a>
          <a
            href="/video"
            class="inline-flex min-w-[200px] items-center justify-center rounded-xl border-2 border-slate-700/80 bg-white/50 px-6 py-3 font-semibold text-slate-900 transition hover:bg-white/80 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2"
            aria-label="Watch our video about soil testing"
          >
            Watch Video
          </a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

---
import SiteLayout from '../layouts/SiteLayout.astro';
import { importanceCards, soilIssueGroups, whyItMattersIntro } from '../data/data.js';
import { SKY_FACTOR_TILE_CLASS, SKY_OUTCOME_TILE_CLASS } from '../data/skyTileClasses.js';

const factorTile = `${SKY_FACTOR_TILE_CLASS} transition-all duration-200 ease-out motion-reduce:transition-none hover:-translate-y-1 hover:scale-[1.02] hover:border-sky-400 hover:shadow-lg hover:from-sky-100/90 hover:to-white motion-reduce:hover:translate-y-0 motion-reduce:hover:scale-100 motion-reduce:hover:shadow-sm group`;

const outcomeTile = `${SKY_OUTCOME_TILE_CLASS} transition-all duration-200 ease-out motion-reduce:transition-none hover:-translate-y-0.5 hover:scale-[1.015] hover:border-sky-400 hover:shadow-lg hover:from-sky-100/90 hover:to-white motion-reduce:hover:translate-y-0 motion-reduce:hover:scale-100 motion-reduce:hover:shadow-sm group`;
---

<SiteLayout
  title="Why Soil Testing Matters - GeoDesign"
  description="Why ground investigation matters: reducing construction risk with scientific soil and site analysis before design and build."
  canonicalPath="/why-it-matters"
>
  <div class="page-shell-white">
    <div class="page-shell-inner">
      <section id="issue" class="w-full min-w-0 py-8 md:py-10" aria-labelledby="issue-heading">
        <h1
          id="issue-heading"
          class="mb-5 text-center text-3xl font-bold text-slate-900 md:mb-6 sm:text-4xl"
        >
          Why Soil Testing Matters?
        </h1>
        <p class="mx-auto mb-10 max-w-3xl text-center text-base leading-relaxed text-slate-600 md:mb-12 md:text-lg">
          {whyItMattersIntro}
        </p>

        <h2 id="site-factors-heading" class="mb-2 text-center text-2xl font-bold text-slate-900 md:text-3xl">
          What affects your site
        </h2>
        <p class="mx-auto mb-8 max-w-2xl text-center text-sm text-slate-600 md:mb-10 md:text-base">
          Ground conditions, water, earthworks, and land use — each plays a role in safe foundation design.
        </p>

        <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-2 md:mb-12 md:gap-5 lg:grid-cols-3">
          {
            soilIssueGroups.flatMap((group) =>
              group.items.map((issue, itemIndex) => {
                const issueId = `issue-${group.id}-${itemIndex}`;
                return (
                  <div class={factorTile} role="article" aria-labelledby={issueId}>
                    <span
                      class="mb-2 block text-4xl text-sky-600 transition-colors duration-200 group-hover:text-sky-700"
                      aria-hidden="true"
                    >
                      {issue.icon}
                    </span>
                    <h3 id={issueId} class="mb-1.5 text-base font-bold text-slate-900 md:text-lg">
                      {issue.title}
                    </h3>
                    <p class="text-sm leading-snug text-slate-600">{issue.description}</p>
                  </div>
                );
              })
            )
          }
        </div>

        <div class="border-t border-stone-200/80 pt-10 md:pt-12" aria-labelledby="outcomes-heading">
          <h2 id="outcomes-heading" class="mb-2 text-center text-2xl font-bold text-slate-900 md:text-3xl">
            What you gain from testing
          </h2>
          <p class="mx-auto mb-8 max-w-2xl text-center text-sm text-slate-600 md:mb-10 md:text-base">
            Clear data supports better decisions before you build — not after problems appear.
          </p>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
            {
              importanceCards.map((card, index) => (
                <div class={outcomeTile} role="article" aria-labelledby={`importance-${index}`}>
                  <span
                    class="mb-4 block text-5xl text-sky-600 transition-colors duration-200 group-hover:text-sky-700"
                    aria-hidden="true"
                  >
                    {card.icon}
                  </span>
                  <h3 id={`importance-${index}`} class="mb-3 text-xl font-bold text-slate-900 md:text-2xl">
                    {card.title}
                  </h3>
                  <p class="text-base leading-relaxed text-slate-600">{card.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>
    </div>
  </div>
</SiteLayout>
